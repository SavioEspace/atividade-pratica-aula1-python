    "import plotly.express as px\n",
    "df = pd.read_csv('vendas_brasil_clean_aula6_plotly.csv')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "8f895627",
   "metadata": {},
   "outputs": [],
   "source": [
    "fig = px.bar(df.groupby('uf')['receita'].sum().reset_index(), x='uf', y='receita')\n",
    "fig.show()"
   ]
  },
